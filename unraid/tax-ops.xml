<?xml version="1.0"?>
<Container version="2">
  <Name>tax-ops</Name>
  <Repository>ghcr.io/jwright81/tax-ops:latest</Repository>
  <Registry>https://ghcr.io</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/jwright81/tax-ops</Support>
  <Project>https://github.com/jwright81/tax-ops</Project>
  <Overview>Tax office document intake, OCR, review, filing, and 1099-B/TXF operations app.</Overview>
  <Category>Productivity:</Category>
  <WebUI>http://[IP]:[PORT:3000]</WebUI>
  <Icon>https://raw.githubusercontent.com/jwright81/tax-ops/main/docs/assets/icon.png</Icon>
  <TemplateURL>https://raw.githubusercontent.com/jwright81/tax-ops/main/unraid/tax-ops.xml</TemplateURL>
  <Config Name="Web UI Port" Target="3000" Default="3000" Mode="tcp" Description="Port for tax-ops web UI and API" Type="Port" Display="always" Required="true" Mask="false">3000</Config>
  <Config Name="App Data" Target="/data" Default="/mnt/user/appdata/tax-ops/data" Mode="rw" Description="Tax-ops document storage root" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/tax-ops/data</Config>
  <Config Name="DB Host" Target="DB_HOST" Default="192.168.1.10" Mode="" Description="MariaDB host or IP" Type="Variable" Display="always" Required="true" Mask="false">192.168.1.10</Config>
  <Config Name="DB Port" Target="DB_PORT" Default="3306" Mode="" Description="MariaDB port" Type="Variable" Display="always" Required="true" Mask="false">3306</Config>
  <Config Name="DB Name" Target="DB_NAME" Default="tax_ops" Mode="" Description="MariaDB database name" Type="Variable" Display="always" Required="true" Mask="false">tax_ops</Config>
  <Config Name="DB User" Target="DB_USER" Default="tax_ops" Mode="" Description="MariaDB username" Type="Variable" Display="always" Required="true" Mask="false">tax_ops</Config>
  <Config Name="DB Password" Target="DB_PASSWORD" Default="" Mode="" Description="MariaDB password" Type="Variable" Display="always" Required="true" Mask="true"></Config>
  <Config Name="Bootstrap Admin Username" Target="BOOTSTRAP_ADMIN_USERNAME" Default="admin" Mode="" Description="Initial admin username if no users exist" Type="Variable" Display="always" Required="true" Mask="false">admin</Config>
  <Config Name="Bootstrap Admin Password" Target="BOOTSTRAP_ADMIN_PASSWORD" Default="" Mode="" Description="Initial admin password used on first run" Type="Variable" Display="always" Required="true" Mask="true"></Config>
  <Config Name="Watch Folder" Target="WATCH_FOLDER" Default="/data/incoming" Mode="" Description="Folder monitored for scanned PDFs" Type="Variable" Display="always" Required="true" Mask="false">/data/incoming</Config>
  <Config Name="Processed Folder" Target="PROCESSED_FOLDER" Default="/data/processed" Mode="" Description="Processed document output folder" Type="Variable" Display="always" Required="true" Mask="false">/data/processed</Config>
  <Config Name="Review Folder" Target="REVIEW_FOLDER" Default="/data/review" Mode="" Description="Folder for review-queued documents" Type="Variable" Display="always" Required="true" Mask="false">/data/review</Config>
  <Config Name="Clients Folder" Target="CLIENTS_FOLDER" Default="/data/clients" Mode="" Description="Client filing root folder" Type="Variable" Display="always" Required="true" Mask="false">/data/clients</Config>
</Container>
